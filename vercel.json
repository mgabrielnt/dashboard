{
  "services": {
    "frontend": {
      "root": ".",
      "framework": "create-react-app"
    },
    "backend": {
      "root": "backend",
      "runtime": "node",
      "entrypoint": "server.demo.js"
    }
  },
  "rewrites": [
    {
      "source": "/api(/.*)?",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/uploads(/.*)?",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}
